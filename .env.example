# ─────────────────────────────────────────────────────────────────────
# NotifyForge — Environment Variables
# Copy to .env and fill in the values you need.
# All provider credentials are OPTIONAL — the platform runs in simulated
# mode without them and switches to real delivery when they're set.
# ─────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────
# SQLite for development; switch to postgresql:// for production.
DATABASE_URL="file:./db/custom.db"

# ── Webhook signing ───────────────────────────────────────────────────
# Used to sign all outbound webhooks with HMAC-SHA256.
WEBHOOK_DEFAULT_SIGNING_KEY="change-me-in-prod"

# ── FCM (Firebase Cloud Messaging — Android Push) ────────────────────
# Paste the entire service account JSON key file contents here.
FCM_SERVICE_ACCOUNT_JSON=""

# ── APNs (Apple Push Notification service — iOS Push) ────────────────
APNS_KEY_ID=""
APNS_TEAM_ID=""
APNS_BUNDLE_ID="com.example.app"
# PEM-formatted ES256 private key (the .p8 file contents).
# Use \n for newlines if setting via env.
APNS_PRIVATE_KEY=""
# Set to "true" to use the sandbox endpoint.
APNS_USE_SANDBOX="false"

# ── Huawei HMS Push Kit ───────────────────────────────────────────────
HMS_APP_ID=""
HMS_APP_SECRET=""

# ── SendGrid (Email) ──────────────────────────────────────────────────
SENDGRID_API_KEY=""

# ── Twilio (SMS) ──────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM="+15551234567"

# ── Web Push (VAPID) ──────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
WEBPUSH_VAPID_PUBLIC_KEY=""
WEBPUSH_VAPID_PRIVATE_KEY=""
WEBPUSH_SUBJECT="mailto:admin@example.com"

# ── Redis (production queue backend — optional) ──────────────────────
REDIS_URL="redis://localhost:6379"

# ── ClickHouse (production analytics — optional) ─────────────────────
CLICKHOUSE_URL="http://localhost:8123"
CLICKHOUSE_USER="notifyforge"
CLICKHOUSE_PASSWORD=""

# ── Observability ────────────────────────────────────────────────────
LOG_LEVEL="info"
OTEL_EXPORTER_OTLP_ENDPOINT=""

# ── Platform ──────────────────────────────────────────────────────────
NODE_ENV="development"
PORT="3000"
